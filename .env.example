# PostgreSQL
POSTGRES_USER=cosmic_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=cosmic_db
DATABASE_URL=postgresql://cosmic_user:change_me_strong_password@db:5432/cosmic_db

# Security
SECRET_KEY=change_me_generate_64_hex

# OAuth
GOOGLE_CLIENT_ID=replace_with_web_google_client_id
GOOGLE_SERVER_CLIENT_ID=replace_with_server_google_client_id

# API
BASE_URL=https://api.cosmicexplorer.uk
ALLOWED_ORIGINS=https://cosmicexplorer.uk,https://www.cosmicexplorer.uk

# Frontend build/runtime values in compose
NEXT_PUBLIC_API_URL=https://api.cosmicexplorer.uk
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_with_web_google_client_id

# Admin system integration
ADMIN_BACKEND_HEALTH_URL=https://api.cosmicexplorer.uk/health
ADMIN_WEB_HEALTH_URL=https://cosmicexplorer.uk

# SMTP for admin campaigns
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@cosmicexplorer.uk
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=no-reply@cosmicexplorer.uk
SMTP_USE_TLS=true

# Optional cloudflare tunnel
CLOUDFLARE_TUNNEL_TOKEN=
