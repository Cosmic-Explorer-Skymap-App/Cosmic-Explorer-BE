# PostgreSQL
POSTGRES_USER=cosmic_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=cosmic_db
DATABASE_URL=postgresql://cosmic_user:CHANGE_ME_strong_password@db:5432/cosmic_db

# JWT - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_random_key

# Google OAuth2 - Web Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Google Gemini AI - Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# CORS - Comma-separated list of allowed origins (leave empty to allow all - dev only)
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Cloudflare Tunnel - Get from Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=YOUR_TUNNEL_TOKEN
